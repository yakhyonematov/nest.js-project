generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id    Int    @id @default(autoincrement())
  title String
  price Float
}

model User {
  id Int @id @default(autoincrement())
  name String
  email String @unique
  password String
}

model User2 {
  id Int @id @default(autoincrement())
  surname String
  job String
  country String
}